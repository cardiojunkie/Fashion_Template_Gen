# Optional Phase 3 image-download overrides. These are the secure defaults.
FASHION_CMS_IMAGE_TOTAL_CONCURRENCY=8
FASHION_CMS_IMAGE_PER_HOST_CONCURRENCY=4
FASHION_CMS_IMAGE_CONNECT_TIMEOUT_SECONDS=10
FASHION_CMS_IMAGE_READ_TIMEOUT_SECONDS=30
FASHION_CMS_IMAGE_RETRY_COUNT=3
FASHION_CMS_IMAGE_MAX_RESPONSE_BYTES=26214400
FASHION_CMS_IMAGE_MAX_DECODED_PIXELS=50000000
# Phase 8 centralized safety limits. Empty optional approval-dependent values are ignored.
FASHION_CMS_WORKBOOK_BYTES=26214400
FASHION_CMS_WORKBOOK_EXPANDED_BYTES=104857600
FASHION_CMS_WORKBOOK_MEMBERS=2000
FASHION_CMS_WORKBOOK_ROWS=100000
FASHION_CMS_WORKBOOK_COLUMNS=500
FASHION_CMS_CELL_CHARACTERS=32767
FASHION_CMS_ZIP_BYTES=104857600
FASHION_CMS_ZIP_EXPANDED_BYTES=524288000
FASHION_CMS_ZIP_MEMBERS=1000
FASHION_CMS_UPLOADED_IMAGE_COUNT=500
FASHION_CMS_IMAGE_BYTES=26214400
FASHION_CMS_IMAGE_PIXELS=50000000
FASHION_CMS_IMAGE_DIMENSION=20000
FASHION_CMS_TOTAL_UPLOAD_BYTES=262144000
FASHION_CMS_URLS_PER_SKU=20
FASHION_CMS_URL_REDIRECTS=5
FASHION_CMS_URL_RESPONSE_BYTES=26214400
FASHION_CMS_URL_CONNECT_TIMEOUT_SECONDS=10
FASHION_CMS_URL_READ_TIMEOUT_SECONDS=30
FASHION_CMS_URL_TOTAL_DEADLINE_SECONDS=120
FASHION_CMS_URL_RETRIES=3
FASHION_CMS_JOB_RUNTIME_SECONDS=3600
FASHION_CMS_MODEL_CONCURRENCY=1
FASHION_CMS_MODEL_RETRIES=2
FASHION_CMS_CALLS_PER_JOB=500
FASHION_CMS_MAXIMUM_ESTIMATED_COST=
FASHION_CMS_CONFIRMATION_COST_THRESHOLD=
FASHION_CMS_RETAINED_JOBS=
FASHION_CMS_RETENTION_DAYS=

# Optional Phase 4 SQLite location. Default: data/fashion_cms.sqlite3
# FASHION_CMS_DB_PATH=data/fashion_cms.sqlite3

# Optional Phase 5 live Topwear extraction. Fake extraction is the default and
# requires none of these values. Keep real keys in the environment or a secret
# store; never commit them.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_IMAGE_DETAIL=high
